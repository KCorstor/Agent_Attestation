# --- Required ---
# Test secret key: Stripe Dashboard → Developers → API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# HMAC binding for MPP challenges (generate once: openssl rand -base64 32)
MPP_SECRET_KEY=

# --- Mock SPT binding (server + agent must match) ---
# Stripe Business Network seller id in the challenge; test default from Stripe docs:
MPP_MOCK_SELLER_NETWORK_ID=internal
# Or use STRIPE_MPP_NETWORK_ID (alias read by mock_spt_env.mjs)

# Stable id for this "seller" when minting SPT (seller_details.external_id)
MPP_MOCK_SELLER_EXTERNAL_ID=mock-seller-attestation-lab

# Mock issuing bank / auction winner (logs + PaymentIntent metadata + MPP credential externalId)
MPP_MOCK_GRANTOR_EXTERNAL_ID=mock-issuing-bank-auction-winner
MPP_MOCK_GRANTOR_LABEL=Mock Issuing Bank (auction winner)

# Optional: reuse a PaymentMethod instead of creating 4242 each run (pm_...)
# MPP_MOCK_PAYMENT_METHOD_ID=

# Default: create PM from Stripe test token (no raw card API)
# MPP_MOCK_STRIPE_CARD_TOKEN=tok_visa

# Raw PAN only if Stripe enabled raw card data on your account:
# MPP_MOCK_USE_RAW_CARD_DATA=1
# MPP_MOCK_CARD_NUMBER=4242424242424242
# MPP_MOCK_CARD_EXP_MONTH=12
# MPP_MOCK_CARD_EXP_YEAR=2034
# MPP_MOCK_CARD_CVC=123

# --- Optional ---
# STRIPE_API_VERSION=2026-03-04.preview
# MPP_REALM=mpp-spt-test
# PORT=4242
# MPP_PAID_URL=http://127.0.0.1:4242/paid

# --- PostalForm (npm run agent:postalform) — https://postalform.com/agents ---
# POSTALFORM_BASE_URL=https://postalform.com
# POSTALFORM_BUYER_EMAIL=you@example.com
# POSTALFORM_BUYER_NAME=Agent Attestation Lab
# POSTALFORM_STRIPE_SELLER_EXTERNAL_ID=
# POSTALFORM_STRIPE_NETWORK_ID=
# POSTALFORM_PDF_PATH=./fixtures/sample-letter.pdf
