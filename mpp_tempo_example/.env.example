# Server: shared secret for MPP challenge binding (generate: openssl rand -base64 32)
MPP_SECRET_KEY=

# Payer wallet (Moderato testnet). Run: npm run wallet:setup — values are saved here; re-run without --force keeps the same key.
# TEMPO_ADDRESS is the 0x address derived from TEMPO_PRIVATE_KEY (informational).
TEMPO_PRIVATE_KEY=
TEMPO_ADDRESS=

# Who receives pathUSD for GET /paid. The setup script sets this to the same as TEMPO_ADDRESS for the demo.
TEMPO_RECIPIENT_ADDRESS=

# Optional: override paid URL (default http://127.0.0.1:4243/paid)
# MPP_PAID_URL=http://127.0.0.1:4243/paid

# Optional: write 402 payment bundle JSON (for auction integration) when running npm run agent
# MPP_BUNDLE_OUT=./last-bundle.json

# Optional: block after 402 until this file exists with JSON (see README "Pause until auction")
# MPP_AUCTION_TERMS_FILE=./terms.json
# MPP_AUCTION_POLL_MS=500
# MPP_AUCTION_TIMEOUT_MS=0
